---
import "../styles/global.css";
import InquiryFormCRM from "../components/InquiryFormCRM";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images/Tesca_logo.svg" />
    <link rel="shortcut icon" href="/images/Tesca_logo.svg" />
    <title>Assessment Form | TESCA Visa Consultancy</title>
    <meta name="description" content="Study Abroad, Visa & Immigration Assessment Form. Please complete the form and our counselor will contact you within 24 hours." />
  </head>
  <body class="bg-gradient-to-br from-slate-50 to-[#0F4C81]/5 min-h-screen flex flex-col items-center justify-center p-3 md:p-8 font-sans">
    
    <!-- Multi-step lead capture component -->
    <main class="w-full flex justify-center">
      <InquiryFormCRM client:load />
    </main>

  </body>
</html>
