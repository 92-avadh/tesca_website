---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`,
  Star: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
};
---

<Layout 
  title="Best IELTS Classes in Surat | Top IELTS Coaching | TESCA"
  description="Enroll in the best IELTS classes in Surat. Physical classroom training at Simada Naka & Mota Varachha. Weekly mock tests, expert tutors, and band-score guarantees."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          IELTS Coaching
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          IELTS Classes in Surat
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          Master the IELTS exam and secure your study visa. TESCA offers the best IELTS classes in Surat with certified trainers, comprehensive study materials, and state-of-the-art classroom facilities in Simada Naka and Mota Varachha.
        </p>

        <div class="flex items-center gap-2 pt-2">
          <div class="flex">
            {[1, 2, 3, 4, 5].map(() => <span set:html={SVG.Star} />)}
          </div>
          <span class="text-xs text-support-gray font-medium">
            Rated 4.9/5 by 1,200+ successful Surat students
          </span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-2 space-y-12 font-sans">
        
        <!-- Coaching Pillars -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Individual Attention</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Small batch sizes ensuring personalized doubt clearing and interactive speaking reviews.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Weekly Mock Tests</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Simulating exam-hall environments every Saturday to track your progress and build confidence.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Flexible Batch Timings</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Morning, afternoon, and evening batches tailored for both college students and working professionals.</p>
          </div>
        </div>

        <!-- Neighbourhood coverage section -->
        <div class="p-6 rounded-2xl border border-slate-100 bg-slate-50/50 leading-relaxed text-sm text-slate-650">
          <h3 class="text-lg font-bold font-display text-slate-800 mb-2">Serving All Neighborhoods in Surat</h3>
          <p>
            With two premium locations, we are the go-to IELTS coaching class for students in <strong>Mota Varachha</strong>, <strong>Adajan</strong>, <strong>Vesu</strong>, <strong>Katargam</strong>, and Simada. We provide complete study materials, Grammar foundation classes, and customized mock test modules to guarantee a 7.0+ band score.
          </p>
        </div>

        <!-- 4 Modules Detail -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Our IELTS Course Syllabus</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {[
              { m: "Listening Module", d: "Spelling checks, accent familiarity drills, and practice with 10+ question variants." },
              { m: "Reading Module", d: "Time management tips, vocabulary building, and skimming/scanning shortcuts." },
              { m: "Writing Module", d: "Task 1 essay structure, Task 2 grammar range enhancement, and daily assessment reviews." },
              { m: "Speaking Module", d: "One-on-one mock interviews, cue-card preparation, and pronunciation polish." }
            ].map(mod => (
              <div class="p-6 rounded-2xl border border-slate-150 bg-white shadow-sm space-y-2">
                <div class="flex items-center gap-2">
                  <div class="p-1 rounded-full bg-emerald-50 text-emerald-600">
                    <span set:html={SVG.Check} />
                  </div>
                  <h4 class="font-bold text-slate-800 text-sm">{mod.m}</h4>
                </div>
                <p class="text-xs text-slate-500 leading-relaxed pl-7">{mod.d}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQs -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {[
              {
                q: "What is the course duration for IELTS training at TESCA?",
                a: "We offer 1-month, 2-month, and 3-month courses based on your current proficiency level. Most students achieve their target score within 8 to 12 weeks of structured training."
              },
              {
                q: "Do you offer both Academic and General IELTS coaching?",
                a: "Yes, we have separate batches for Academic IELTS (for student visas) and General IELTS (for Canada/Australia PR migration)."
              },
              {
                q: "What is the fee structure for IELTS classes in Surat?",
                a: "Fees vary depending on the course duration and batch selection. Please contact our counseling desk or visit our Simada Naka/Mota Varachha branches for current fee tables and active discount offers."
              }
            ].map(faq => (
              <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/60 shadow-sm font-sans">
                <h4 class="font-bold text-slate-850 text-sm flex items-start gap-2 leading-relaxed">
                  <span class="text-accent-blue font-extrabold font-display">Q:</span>
                  <span>{faq.q}</span>
                </h4>
                <p class="text-xs text-slate-500 mt-2 leading-relaxed pl-5 flex items-start gap-2">
                  <span class="text-emerald-600 font-extrabold font-display">A:</span>
                  <span>{faq.a}</span>
                </p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Book a Free Demo Class</h3>
            <p class="text-xs text-slate-500 leading-relaxed">
              Experience our coaching first-hand. Attend a free, no-obligation IELTS demo class at any of our branches.
            </p>
          </div>
          
          <button 
            type="button" 
            onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
            class="w-full py-3 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
          >
            Request Free Demo Class
          </button>
        </div>
      </div>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
