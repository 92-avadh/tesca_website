---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
---

<Layout
  title="AI Google Review Generator | TESCA Visa Consultancy"
  description="Generate a natural, genuine Google review for visa and study abroad consultancy services instantly."
>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-16">
    <!-- Header Banner -->
    <div class="glass-card rounded-[2.5rem] bg-gradient-to-br from-[#E6F2F3] to-white border border-slate-200/60 shadow-lg p-8 md:p-12 relative overflow-hidden mb-10 text-left">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/10 -top-12 -left-12 rounded-full blur-[80px]"></div>
      <div class="relative z-10 space-y-4">
        <span class="inline-block text-xs font-semibold tracking-wider text-[#0A7880] bg-[#0A7880]/10 px-4 py-1.5 rounded-full border border-[#0A7880]/20 font-sans uppercase">
          Google Review Writer
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold font-display text-slate-800 tracking-tight leading-none">
          Google Review Generator
        </h1>
        <p class="text-sm sm:text-base text-slate-600 font-sans font-normal leading-relaxed max-w-2xl">
          Generate an authentic, natural, and realistic Google review (~30 words) for visa consultancy services in real-time. Click countries or visa types below to customize instantly.
        </p>
      </div>
    </div>

    <!-- Main Generator Card -->
    <div class="bg-white border border-slate-200 rounded-[2.5rem] p-6 sm:p-10 shadow-xl relative text-left">
      
      <!-- Generated Review Area (Top Box above button) -->
      <div class="space-y-4 mb-6">
        <div class="flex items-center justify-between">
          <label for="review-output-textarea" class="block text-xs font-bold text-slate-700 uppercase tracking-wider">
            Your Generated Review (~30 words)
          </label>
          <button
            id="copy-btn"
            type="button"
            class="px-4 py-1.5 bg-[#0A7880]/10 text-[#0A7880] hover:bg-[#0A7880]/20 font-bold text-xs rounded-lg transition-all cursor-pointer border border-[#0A7880]/20 flex items-center gap-1.5 active:scale-95"
          >
            Copy Review
          </button>
        </div>
        <textarea
          id="review-output-textarea"
          rows="4"
          readonly
          class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-sm text-slate-700 leading-relaxed focus:outline-none resize-none font-sans font-medium"
          placeholder="Generating review..."
        ></textarea>
      </div>

      <!-- Generate / Regenerate Button (Placed below input box) -->
      <button
        type="button"
        id="submit-btn"
        class="w-full py-4 bg-[#F08A00] hover:bg-[#C06E00] text-white font-bold text-sm rounded-full shadow-md hover:scale-[1.01] transition-all flex items-center justify-center gap-2 cursor-pointer font-sans tracking-wide mb-8 active:scale-95"
      >
        <span>Regenerate Different Version</span>
      </button>

      <!-- Selection Controls -->
      <div class="space-y-8 pt-6 border-t border-slate-100">
        
        <!-- Country Pills Selection -->
        <div class="space-y-3">
          <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider">
            Target Country (Optional)
          </span>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3" id="country-grid">
            <button
              type="button"
              data-value=""
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-indigo-50 border-indigo-500 text-indigo-700"
            >
              🌍 All Countries
            </button>
            <button
              type="button"
              data-value="USA"
              data-code="us"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/us.png" alt="USA flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              USA
            </button>
            <button
              type="button"
              data-value="United Kingdom"
              data-code="gb"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/gb.png" alt="UK flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              UK
            </button>
            <button
              type="button"
              data-value="Canada"
              data-code="ca"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/ca.png" alt="Canada flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Canada
            </button>
            <button
              type="button"
              data-value="Australia"
              data-code="au"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/au.png" alt="Australia flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Australia
            </button>
            <button
              type="button"
              data-value="Germany"
              data-code="de"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/de.png" alt="Germany flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Germany
            </button>
            <button
              type="button"
              data-value="Ireland"
              data-code="ie"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/ie.png" alt="Ireland flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Ireland
            </button>
            <button
              type="button"
              data-value="New Zealand"
              data-code="nz"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/nz.png" alt="New Zealand flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              New Zealand
            </button>
            <button
              type="button"
              data-value="Dubai"
              data-code="ae"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/ae.png" alt="Dubai flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Dubai
            </button>
            <button
              type="button"
              data-value="Singapore"
              data-code="sg"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/sg.png" alt="Singapore flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Singapore
            </button>
          </div>
        </div>

        <!-- Visa Type Pills Selection -->
        <div class="space-y-3">
          <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider">
            Visa Type (Optional)
          </span>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="visa-grid">
            <button
              type="button"
              data-value=""
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-indigo-50 border-indigo-500 text-indigo-700"
            >
              🌐 All Visas
            </button>
            <button
              type="button"
              data-value="Student Visa"
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              🎓 Student Visa
            </button>
            <button
              type="button"
              data-value="Visitor / Tourist Visa"
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              ✈️ Tourist Visa
            </button>
            <button
              type="button"
              data-value="Dependent Visa"
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              👥 Dependent Visa
            </button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <AICounsellor client:only="react" />
</Layout>

<script>
  function setupReviewGenerator() {
    let selectedCountry = "";
    let selectedVisaType = "";

    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const reviewOutput = document.getElementById("review-output-textarea") as HTMLTextAreaElement;
    const copyBtn = document.getElementById("copy-btn");

    const countryPills = document.querySelectorAll(".country-pill");
    const visaPills = document.querySelectorAll(".visa-pill");

    if (!reviewOutput || !submitBtn) return;

    // Helper to request API
    async function generateReview() {
      // Show loader
      if ((window as any).showBtnLoader) {
        (window as any).showBtnLoader(submitBtn, "Generating...");
      } else {
        submitBtn.disabled = true;
        submitBtn.textContent = "Generating...";
      }
      reviewOutput.value = "Generating your review...";

      try {
        const res = await fetch("/api/generate-review", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            country: selectedCountry,
            visaType: selectedVisaType
          })
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || "Failed to generate review.");
        }

        const data = await res.json();
        reviewOutput.value = data.review || "No review generated.";

      } catch (err: any) {
        console.error("Generator Error:", err);
        reviewOutput.value = `Error: ${err.message || "An unexpected error occurred."}`;
      } finally {
        // Hide loader
        if ((window as any).hideBtnLoader) {
          (window as any).hideBtnLoader(submitBtn);
          submitBtn.textContent = "Regenerate Different Version";
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = "Regenerate Different Version";
        }
      }
    }

    // Set active styles helper
    function updateActivePills(pills: NodeListOf<Element>, activeValue: string, activeClasses: string[], inactiveClasses: string[]) {
      pills.forEach((pill) => {
        const value = pill.getAttribute("data-value") || "";
        if (value === activeValue) {
          pill.classList.remove(...inactiveClasses);
          pill.classList.add(...activeClasses);
        } else {
          pill.classList.remove(...activeClasses);
          pill.classList.add(...inactiveClasses);
        }
      });
    }

    const activeStyles = ["bg-indigo-50", "border-indigo-500", "text-indigo-700"];
    const inactiveStyles = ["bg-white", "border-slate-200", "text-slate-700"];

    // Country selection
    countryPills.forEach((pill) => {
      pill.addEventListener("click", () => {
        selectedCountry = pill.getAttribute("data-value") || "";
        updateActivePills(countryPills, selectedCountry, activeStyles, inactiveStyles);
        generateReview();
      });
    });

    // Visa selection
    visaPills.forEach((pill) => {
      pill.addEventListener("click", () => {
        selectedVisaType = pill.getAttribute("data-value") || "";
        updateActivePills(visaPills, selectedVisaType, activeStyles, inactiveStyles);
        generateReview();
      });
    });

    // Manual regenerate click
    submitBtn.addEventListener("click", () => {
      generateReview();
    });

    // Copy to clipboard helper
    if (copyBtn) {
      copyBtn.addEventListener("click", () => {
        const text = reviewOutput.value || "";
        if (!text || text === "Generating your review...") return;
        navigator.clipboard.writeText(text).then(() => {
          copyBtn.textContent = "Copied!";
          setTimeout(() => {
            copyBtn.textContent = "Copy Review";
          }, 1800);
        }).catch((err) => {
          console.error("Failed to copy text:", err);
        });
      });
    }

    // Trigger initial load review
    generateReview();
  }

  // Bind handlers on swap/load
  setupReviewGenerator();
  document.addEventListener("astro:page-load", setupReviewGenerator);
</script>
