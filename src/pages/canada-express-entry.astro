---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`
};
---

<Layout 
  title="Canada Express Entry & CRS Score Calculator Guide | TESCA"
  description="Master Canada's Express Entry. Point scoring systems, CRS calculation factors, category-based draws, and positive provincial PNP boosts."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left font-sans">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          Canada Immigration
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Canada Express Entry Guide
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          The ultimate guide to Express Entry. Learn how to optimize your Comprehensive Ranking System (CRS) score, target category-based draws, and leverage provincial nominations.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-2 space-y-12">
        
        <!-- Highlights -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">CRS Scoring</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Understand point distributions for age, qualifications, work history, and foreign language skills.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Category-Based Selection</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Targeting specific job-class draws (STEM, Healthcare, Trades) that require lower overall CRS cutoffs.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">PNP Integration</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Filing in provincial portals (e.g. OINP, SINP) to unlock a 600-point boost that guarantees an ITA.</p>
          </div>
        </div>

        <!-- Requirements -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Express Entry Core Pillars</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              "Federal Skilled Worker (FSW) qualification requirements",
              "Canadian Experience Class (CEC) - for those with Canadian work history",
              "Educational Credential Assessment (ECA) to prove degree value",
              "Language Benchmark (CLB) requirements - IELTS or CELPIP",
              "NOC / TEER classification system check",
              "Proof of Funds validation criteria"
            ].map(doc => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-100 bg-white shadow-sm">
                <div class="p-1 rounded-full bg-emerald-50 text-emerald-600">
                  <span set:html={SVG.Check} />
                </div>
                <span class="text-xs font-semibold text-slate-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Application Steps -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-850 tracking-tight">Filing Checklist Timeline</h2>
          <div class="relative pl-6 border-l-2 border-slate-200 space-y-8">
            {[
              "Calculate your estimated points and assess NOC classifications",
              "Fulfill ECA evaluations and clear language testing with CLB 9+ target",
              "Submit Express Entry profile into the IRCC federal pool",
              "Leverage provincial nominee streams to boost CRS by 600 points",
              "Receive Invitation to Apply (ITA) and submit full PR documentation e-APR"
            ].map((step, idx) => (
              <div class="relative">
                <div class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-accent-blue border-4 border-white shadow-sm"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Step {idx + 1}</span>
                <p class="text-sm font-semibold text-slate-700 mt-1">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Want to check your CRS Score?</h3>
            <p class="text-xs text-slate-500 leading-relaxed">
              Book a consultation to evaluate your profile points, NOC classification, and Provincial Nominee (PNP) opportunities.
            </p>
          </div>
          
          <button 
            type="button" 
            onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
            class="w-full py-3 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
          >
            Calculate CRS & Consult
          </button>
        </div>
      </div>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
