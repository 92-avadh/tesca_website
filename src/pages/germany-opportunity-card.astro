---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`
};
---

<Layout 
  title="Germany Opportunity Card (Chancenkarte) Calculator | TESCA"
  description="Calculate your Chancenkarte eligibility points online. Complete guide to requirements, blocked accounts, and Germany job-seeker permits."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          Specialized Visas
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Germany Opportunity Card
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          The Chancenkarte points calculator. Germany's new points-based system allows skilled professionals to live and seek employment in Germany for up to 1 year.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Interactive Points Calculator Widget (7 cols) -->
      <div class="lg:col-span-7 p-6 md:p-8 rounded-3xl border border-slate-200/80 bg-white shadow-md space-y-6 font-sans">
        <div>
          <h2 class="text-xl font-bold font-display text-slate-850">Chancenkarte Points Calculator</h2>
          <p class="text-xs text-slate-500 mt-1">Select your qualifications below. You need a minimum of <strong>6 points</strong> to qualify.</p>
        </div>

        <form id="chancenkarte-form" class="space-y-6 text-sm text-slate-700">
          
          <!-- Age Group -->
          <div class="space-y-2">
            <label class="block font-bold text-slate-800">1. Age group</label>
            <select id="calc-age" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-accent-blue">
              <option value="2">Up to 35 years old (+2 points)</option>
              <option value="1">35 to 40 years old (+1 point)</option>
              <option value="0">Over 40 years old (+0 points)</option>
            </select>
          </div>

          <!-- Professional Experience -->
          <div class="space-y-2">
            <label class="block font-bold text-slate-800">2. Professional Experience</label>
            <select id="calc-exp" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-accent-blue">
              <option value="3">5+ years experience in last 7 years (+3 points)</option>
              <option value="2">2+ years experience in last 5 years (+2 points)</option>
              <option value="0">Less than 2 years experience (+0 points)</option>
            </select>
          </div>

          <!-- Language Proficiency -->
          <div class="space-y-2">
            <label class="block font-bold text-slate-800">3. Language Proficiency</label>
            <select id="calc-lang" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-accent-blue">
              <option value="3">German B1 or higher (+3 points)</option>
              <option value="2">German A2 (+2 points)</option>
              <option value="1">German A1 or English B2 (+1 point)</option>
              <option value="0">None of the above (+0 points)</option>
            </select>
          </div>

          <!-- Qualification Recognition -->
          <div class="space-y-2">
            <label class="block font-bold text-slate-800">4. Foreign Degree Recognition</label>
            <select id="calc-deg" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-accent-blue">
              <option value="4">Fully recognized foreign degree (+4 points)</option>
              <option value="2">Partially recognized / H+ database listing (+2 points)</option>
              <option value="0">Unrecognized degree (+0 points)</option>
            </select>
          </div>

          <!-- Previous Stay in Germany -->
          <div class="space-y-2">
            <label class="block font-bold text-slate-800">5. Previous German Stay (min. 6 months in last 5 years)</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="calc-stay" value="1" class="w-4 h-4 text-accent-blue" />
                <span>Yes (+1 point)</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="calc-stay" value="0" checked class="w-4 h-4 text-accent-blue" />
                <span>No (+0 points)</span>
              </label>
            </div>
          </div>

          <!-- Result box -->
          <div id="calc-result" class="p-6 rounded-2xl bg-slate-50 border border-slate-150/80 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div>
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Your Estimated Score</span>
              <span id="score-display" class="text-4xl font-extrabold font-display text-accent-blue">10 / 14</span>
            </div>
            <div class="text-right">
              <span id="status-display" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800">
                Eligible to Apply (6+ Points)
              </span>
            </div>
          </div>

        </form>
      </div>

      <!-- Right column Details and CTA (5 cols) -->
      <div class="lg:col-span-5 space-y-6 font-sans">
        <div class="p-8 rounded-3xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-4 text-slate-650 text-sm">
          <h3 class="text-lg font-bold font-display text-slate-800">Key Chancenkarte Facts</h3>
          <ul class="space-y-3 list-disc pl-5">
            <li>Must hold an academic degree or vocational qualification.</li>
            <li>Allows you to work up to 20 hours per week in trial employment while looking for a permanent role.</li>
            <li>Requires a Blocked Account or sponsorship guarantee of at least €1,027/month to cover living costs.</li>
          </ul>
        </div>

        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Need a Germany Job Seeker Visa?</h3>
            <p class="text-xs text-slate-500 leading-relaxed">
              Book a profiling audit to verify your degree recognition on ANABIN and prepare your blocking account dossier.
            </p>
          </div>
          
          <button 
            type="button" 
            onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
            class="w-full py-3 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
          >
            Start German Chancenkarte Filing
          </button>
        </div>
      </div>

    </div>

  </section>

  <!-- Interactive script to handle calculations -->
  <script is:inline>
    function calculatePoints() {
      const ageVal = Number(document.getElementById('calc-age').value) || 0;
      const expVal = Number(document.getElementById('calc-exp').value) || 0;
      const langVal = Number(document.getElementById('calc-lang').value) || 0;
      const degVal = Number(document.getElementById('calc-deg').value) || 0;
      
      const stayRadio = document.querySelector('input[name="calc-stay"]:checked');
      const stayVal = stayRadio ? Number(stayRadio.value) : 0;

      const total = ageVal + expVal + langVal + degVal + stayVal;

      const scoreEl = document.getElementById('score-display');
      const statusEl = document.getElementById('status-display');

      if (scoreEl) scoreEl.textContent = `${total} / 14`;

      if (statusEl) {
        if (total >= 6) {
          statusEl.textContent = "Eligible to Apply (6+ Points)";
          statusEl.className = "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800";
        } else {
          statusEl.textContent = "Not Eligible Yet (< 6 Points)";
          statusEl.className = "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-red-100 border border-red-200 text-red-800";
        }
      }
    }

    function initCalculator() {
      const form = document.getElementById('chancenkarte-form');
      if (form) {
        form.addEventListener('change', calculatePoints);
        calculatePoints();
      }
    }

    document.addEventListener('DOMContentLoaded', initCalculator);
    document.addEventListener('astro:page-load', initCalculator);
  </script>

  <AICounsellor client:only="react" />
</Layout>
