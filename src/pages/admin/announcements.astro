---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { env } from "cloudflare:workers";
import { Trash2, Plus, ShieldAlert } from "lucide-react";

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

const db = env?.tesca_db || env?.DB;

let announcements = [];
let successMessage = "";
let errorMessage = "";

// Handle server actions (Add / Delete)
if (Astro.request.method === "POST" && db) {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-announcement") {
      const id = formData.get("id");
      await db.prepare("DELETE FROM announcements WHERE id = ?").bind(id).run();
      successMessage = "Announcement alert text deleted successfully.";
    } else if (action === "add-announcement") {
      const text = formData.get("text")?.toString().trim();
      if (text) {
        await db.prepare("INSERT INTO announcements (text) VALUES (?)").bind(text).run();
        successMessage = "New announcement alert bar message posted.";
      } else {
        errorMessage = "Announcement text cannot be empty.";
      }
    }
  } catch (err: any) {
    console.error("Action error on announcements page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch announcements
if (db) {
  try {
    const res = await db.prepare("SELECT * FROM announcements ORDER BY id ASC").all();
    announcements = res.results || [];
  } catch (err) {
    console.error("Failed to load announcements:", err);
    errorMessage = "Failed to load database records.";
  }
}
---

<Layout 
  title="Manage Announcement Bar Alerts | TESCA Admin"
  description="Administrative portal to configure announcement banner alert strings."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-950 text-white font-sans flex flex-col">
    <AdminHeader activeTab="announcements" />

    <main class="max-w-7xl mx-auto w-full px-4 md:px-8 py-10 flex-grow text-left">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-white">
          Announcement Alert Bar
        </h1>
        <p class="text-slate-400 text-xs mt-1">Configure alerts rotating dynamically in the header strip at the top of the website.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="p-4 bg-rose-500/10 border border-rose-500/20 rounded-2xl text-rose-300 text-xs font-semibold mb-6 flex items-center gap-2">
          <ShieldAlert class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl text-emerald-300 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Form panel (5 cols) */}
        <div class="lg:col-span-5 bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-xl">
          <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
            <Plus class="w-4 h-4 text-indigo-400" /> Post New Announcement
          </h2>
          
          <form method="POST" class="space-y-4 text-xs font-semibold text-slate-300">
            <input type="hidden" name="action" value="add-announcement" />
            
            <div class="space-y-1.5">
              <label for="announcement-text" class="text-[10px] text-slate-400 uppercase tracking-wide">Announcement Alert Message *</label>
              <textarea 
                id="announcement-text" 
                name="text" 
                required 
                rows="4" 
                class="w-full px-4 py-3 rounded-xl border border-slate-800 bg-slate-950 text-white placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-indigo-500 text-xs leading-relaxed" 
                placeholder="e.g. September 2026 priority intakes are now open — only 10 consultation slots remaining this week!"
              ></textarea>
            </div>

            <button type="submit" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2">
              Publish Announcement
            </button>
          </form>
        </div>

        {/* List panel (7 cols) */}
        <div class="lg:col-span-7 space-y-4">
          <h2 class="text-base font-bold text-white">
            Active Rotations ({announcements.length})
          </h2>

          {announcements.length === 0 ? (
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-10 text-center">
              <p class="text-xs text-slate-500">No announcements found in database. The website will display fallback defaults.</p>
            </div>
          ) : (
            <div class="space-y-3">
              {announcements.map((a) => (
                <div class="flex items-center justify-between gap-4 p-4 rounded-2xl border border-slate-800 bg-slate-900 shadow-md">
                  <p class="text-xs text-slate-200 font-sans font-semibold leading-relaxed">{a.text}</p>
                  <form method="POST" onsubmit="return confirm('Are you sure you want to delete this announcement?');" class="shrink-0">
                    <input type="hidden" name="action" value="delete-announcement" />
                    <input type="hidden" name="id" value={a.id} />
                    <button
                      type="submit"
                      class="p-2 text-rose-400 hover:bg-rose-500/10 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-500/20"
                      aria-label="Delete announcement"
                    >
                      <Trash2 class="w-3.5 h-3.5" />
                    </button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </div>

      </div>

    </main>
  </div>
</Layout>
