---
import Layout from "../layouts/Layout.astro";
import { ShieldAlert, AlertCircle } from "lucide-react";
import { checkAdminAuth, hashToken } from "../utils/adminAuth";
import { env } from "cloudflare:workers";

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (isAuthenticated) {
  return Astro.redirect("/admin/dashboard");
}

let errorMessage = "";

// Handle Login request
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "login") {
      const email = formData.get("email");
      const password = formData.get("password");

      const expectedEmail = env?.ADMIN_EMAIL || import.meta.env.ADMIN_EMAIL || "admin@tesca.com";
      const expectedPassword = env?.ADMIN_PASSWORD || import.meta.env.ADMIN_PASSWORD || "admin1234";

      if (email === expectedEmail && password === expectedPassword) {
        const expectedHash = await hashToken(expectedPassword);
        Astro.cookies.set("admin_session", expectedHash, {
          path: "/",
          httpOnly: true,
          secure: true,
          maxAge: 60 * 60 * 24, // 1 day
        });
        return Astro.redirect("/admin/dashboard");
      } else {
        errorMessage = "Invalid email or password credentials.";
      }
    } else if (action === "logout") {
      Astro.cookies.delete("admin_session", { path: "/" });
      return Astro.redirect("/admin");
    }
  } catch (err) {
    console.error("Login process error:", err);
    errorMessage = "An unexpected error occurred during login.";
  }
}
---

<Layout 
  title="Admin Authentication Portal | TESCA"
  description="Secure access configuration for TESCA web portals."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-900 flex items-center justify-center p-6 text-left font-sans">
    
    <div class="max-w-md w-full">
      {/* Brand logo or header */}
      <div class="text-center mb-8">
        <span class="inline-block text-xs font-bold bg-white/10 text-white/90 px-4 py-1.5 rounded-full border border-white/10 uppercase tracking-widest font-sans">
          TESCA Control Center
        </span>
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-white mt-4">
          Administrative Sign In
        </h1>
        <p class="text-xs text-slate-400 font-sans mt-1">Enter your secure credentials to continue.</p>
      </div>

      {/* Errors */}
      {errorMessage && (
        <div class="flex items-center gap-3 p-4 bg-rose-500/10 border border-rose-500/20 rounded-2xl text-rose-300 text-sm mb-6 font-medium animate-pulse">
          <AlertCircle class="w-5 h-5 text-rose-400 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}

      {/* Card */}
      <div class="bg-slate-800 border border-slate-700/60 rounded-3xl p-8 shadow-xl">
        <div class="w-12 h-12 rounded-2xl bg-indigo-500/10 text-indigo-400 flex items-center justify-center mx-auto mb-6 border border-indigo-500/15">
          <ShieldAlert class="w-6 h-6" />
        </div>
        
        <form method="POST" class="space-y-5">
          <input type="hidden" name="action" value="login" />
          
          <div class="space-y-1.5">
            <label for="email" class="text-xs font-bold text-slate-400 uppercase tracking-wider">Email Address</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full px-4 py-3 rounded-xl border border-slate-700 bg-slate-900/60 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 font-sans text-sm transition-all"
              placeholder="admin@example.com"
            />
          </div>
          
          <div class="space-y-1.5">
            <label for="password" class="text-xs font-bold text-slate-400 uppercase tracking-wider">Security Password</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              required 
              class="w-full px-4 py-3 rounded-xl border border-slate-700 bg-slate-900/60 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 font-sans text-sm transition-all"
              placeholder="••••••••"
            />
          </div>
          
          <button 
            type="submit" 
            class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-4"
          >
            Authenticate Credentials
          </button>
        </form>
      </div>

      <div class="text-center mt-8">
        <a href="/" class="text-xs font-semibold text-slate-500 hover:text-slate-400 transition-colors">
          ← Return to Client Homepage
        </a>
      </div>
    </div>

  </div>
</Layout>
