---
import Layout from "../layouts/Layout.astro";
import EligibilityForm from "../components/EligibilityForm";
import AICounsellor from "../components/AICounsellor";
---

<Layout
  title="University Eligibility Finder | TESCA Study Destinations"
  description="Input your academic profile and tuition budget to see eligible universities and scholarship opportunities across USA, UK, Canada, Australia, Germany, and more."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12">
    <!-- Header Banner -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 items-center p-6 sm:p-8 md:p-12 relative mb-10 sm:mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      <div class="md:col-span-7 space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-[#F08A00] bg-[#FFE5CC] px-4 py-1.5 rounded-full border border-[#F08A00]/20 font-sans uppercase">
          Admissions Eligibility Finder
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Check Your University Match in 2 Minutes
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          Enter your academic scores, test results, and budget details to instantly discover which world-class partner universities you qualify for.
        </p>
      </div>
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center">
        <div class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-accent-blue/15">
          <img 
            src="/images/universities_hero.png" 
            alt="Check Eligibility" 
            class="object-cover w-full h-full select-none"
          />
        </div>
      </div>
    </div>

    <!-- Interactive Finder Form (client-side React) -->
    <!-- EligibilityForm is commented out for now to show Coming Soon block -->
    <!-- <EligibilityForm client:load /> -->
    <div class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-white p-8 md:p-12 text-center shadow-lg max-w-3xl mx-auto">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-accent-blue/5 rounded-full blur-[80px] pointer-events-none"></div>
      
      <div class="relative z-10 max-w-lg mx-auto space-y-6">
        <div class="w-16 h-16 bg-blue-50 text-accent-blue rounded-2xl flex items-center justify-center mx-auto shadow-inner border border-blue-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-blue animate-pulse"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        
        <h2 class="text-2xl md:text-3xl font-extrabold font-display text-slate-800 tracking-tight">
          Admissions Eligibility Finder
        </h2>
        
        <span class="inline-block px-4 py-1.5 bg-amber-50 text-amber-700 border border-amber-200 text-[10px] font-bold uppercase tracking-wider rounded-full">
          Coming Soon
        </span>
        
        <p class="text-sm text-slate-500 font-sans leading-relaxed font-normal">
          We are currently aggregating intake criteria for over 500+ global universities. In the meantime, you can speak directly with our certified advisors to check your eligible programs instantly.
        </p>
        
        <button
          onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#F08A00] hover:bg-[#C06E00] text-white font-bold text-xs rounded-full shadow-md hover:scale-[1.02] transition-all cursor-pointer font-sans uppercase tracking-wider"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Consult An Advisor Now
        </button>
      </div>
    </div>
  </section>

  <AICounsellor client:load />
</Layout>
