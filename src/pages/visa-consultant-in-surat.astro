---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`,
  MapPin: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-accent-blue"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  Phone: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-accent-blue"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
};
---

<Layout 
  title="Best Visa Consultant in Surat | Student & PR Visas | TESCA"
  description="TESCA is Surat's premier visa consultancy. Visit our Simada Naka and Mota Varachha branches for student visa, PR immigration, and visitor visa advice."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-flex items-center gap-1.5 text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          Surat Local Branch
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Visa Consultant in Surat
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          Surat's leading student visa and immigration advisory. With over 20 years of experience and a 97% visa success SLA, we operate two premium physical branches in Surat to support your ambitions.
        </p>

        <!-- Dynamic reviews badge -->
        <div class="flex items-center gap-2 pt-2">
          <div class="flex text-amber-400 text-lg">★★★★★</div>
          <span class="text-xs text-support-gray font-medium">
            <strong id="surat-review-count">900+</strong> Google Reviews (4.9 Stars rating)
          </span>
        </div>
      </div>
    </div>

    <!-- Branch locations grid -->
    <div class="space-y-6 mb-16">
      <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight text-left">Our Surat Branches</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <!-- Simada Naka Branch -->
        <div class="p-8 rounded-3xl bg-slate-50 border border-slate-200/60 shadow-sm flex flex-col justify-between space-y-6 font-sans">
          <div class="space-y-4">
            <div class="w-10 h-10 rounded-xl bg-accent-blue/10 flex items-center justify-center text-accent-blue shadow-sm">
              <span set:html={SVG.MapPin} />
            </div>
            <h3 class="text-xl font-bold text-slate-800 font-display">Simada Naka Branch</h3>
            <p class="text-sm text-slate-650 leading-relaxed">
              110, 111, 112, Royal Arcade, Simada Naka, Surat, Gujarat 395013
            </p>
          </div>
          <div class="flex flex-col gap-3 pt-4 border-t border-slate-200/60">
            <a 
              href="https://www.google.com/maps/search/?api=1&query=110%2C+111%2C+112%2C+Royal+Arcade%2C+Simada+Naka%2C+Surat%2C+Gujarat+395013" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-full py-2.5 bg-white border border-slate-200 hover:bg-slate-100 hover:border-slate-350 text-slate-700 font-semibold text-xs rounded-xl transition-all shadow-sm flex items-center justify-center gap-1.5"
            >
              Get Directions on Map
            </a>
          </div>
        </div>

        <!-- Mota Varachha Branch -->
        <div class="p-8 rounded-3xl bg-slate-50 border border-slate-200/60 shadow-sm flex flex-col justify-between space-y-6 font-sans">
          <div class="space-y-4">
            <div class="w-10 h-10 rounded-xl bg-accent-blue/10 flex items-center justify-center text-accent-blue shadow-sm">
              <span set:html={SVG.MapPin} />
            </div>
            <h3 class="text-xl font-bold text-slate-800 font-display">Mota Varachha Branch</h3>
            <p class="text-sm text-slate-650 leading-relaxed">
              Ambika Pinnacle, 106-107, Lajamni Chowk, Maruti Dham Society, Mota Varachha, Surat, Gujarat 394101
            </p>
          </div>
          <div class="flex flex-col gap-3 pt-4 border-t border-slate-200/60">
            <a 
              href="https://www.google.com/maps/search/?api=1&query=Ambika+Pinnacle%2C+106-107%2C+Lajamni+Chowk%2C+Maruti+Dham+Society%2C+Mota+Varachha%2C+Surat%2C+Gujarat+394101" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-full py-2.5 bg-white border border-slate-200 hover:bg-slate-100 hover:border-slate-350 text-slate-700 font-semibold text-xs rounded-xl transition-all shadow-sm flex items-center justify-center gap-1.5"
            >
              Get Directions on Map
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- Core Services in Surat -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start mb-16">
      
      <div class="lg:col-span-2 space-y-8 font-sans">
        <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Our Study & Immigration Services</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { t: "Student Visas", d: "End-to-end applications for Canada, UK, USA, Australia, and Germany public universities." },
            { t: "PR & Immigration", d: "Express Entry, provincial nominee programs (PNP) and points calculator counseling." },
            { t: "Visitor & Tourist Visas", d: "Detailed documentation auditing, flight bookings, and Schengen visa assistance." },
            { t: "IELTS & PTE Training", d: "In-person and online coaching led by master tutors to secure target scores." }
          ].map(srv => (
            <div class="p-6 rounded-2xl bg-white border border-slate-200 shadow-sm space-y-2">
              <h4 class="font-bold text-slate-800">{srv.t}</h4>
              <p class="text-xs text-slate-500 leading-relaxed">{srv.d}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column sidebar CTA -->
      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Book Surat Appointment</h3>
            <p class="text-xs text-slate-500 leading-relaxed">
              Schedule a free 1-on-1 profiling session with our senior counsellors at either of our Surat branches.
            </p>
          </div>
          
          <button 
            type="button" 
            onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
            class="w-full py-3 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
          >
            Schedule Free Meeting
          </button>
        </div>
      </div>

    </div>

  </section>

  <!-- Load Dynamic ratings stats script -->
  <script is:inline>
    async function loadSuratRating() {
      try {
        const res = await fetch('/api/google-rating');
        if (res.ok) {
          const data = await res.json();
          const target = document.getElementById('surat-review-count');
          if (target && data.reviewCount) {
            target.textContent = Number(data.reviewCount).toLocaleString() + "+";
          }
        }
      } catch (err) {
        console.warn("Local rating fetch failed:", err);
      }
    }
    document.addEventListener('DOMContentLoaded', loadSuratRating);
    document.addEventListener('astro:page-load', loadSuratRating);
  </script>

  <AICounsellor client:only="react" />
</Layout>
